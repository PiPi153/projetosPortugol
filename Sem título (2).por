programa {
  funcao inicio() {

    cadeia nome
    inteiro datanascimento
    inteiro idade
    
    escreva ("Qual o seu Nome:")
    leia(nome)

    escreva("Qual ano você nasceu:")
    leia(datanascimento)

    idade = 2026 - datanascimento

    escreva("Olá", nome, "Sua idade é:", idade, "anos.")

    
  }
}
